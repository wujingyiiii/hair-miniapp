<!-- 我的 -->
<view class="page">
  <view class="page-bg">
  </view>

  <view class="content-area">
    <!-- 用户信息 -->
    <view class="glass-card user-section">
      <view class="user-row" bindtap="doLogin">
        <view class="user-avatar">{{avatarText}}</view>
        <view class="user-info">
          <text class="user-name">{{isLoggedIn ? userInfo.nickName : '点击登录'}}</text>
          <text class="user-phone">{{isLoggedIn ? (userInfo.phone || '已绑定') : '登录后享受会员权益'}}</text>
        </view>
        <text class="arrow">›</text>
      </view>

      <!-- 登录后的会员简卡 -->
      <view class="member-brief" wx:if="{{isLoggedIn && memberInfo}}">
        <view class="brief-item" bindtap="goMember">
          <text class="brief-num">{{memberInfo.points}}</text>
          <text class="brief-label">积分</text>
        </view>
        <view class="brief-divider"></view>
        <view class="brief-item" bindtap="goMember">
          <text class="brief-num">¥{{memberInfo.balance}}</text>
          <text class="brief-label">余额</text>
        </view>
        <view class="brief-divider"></view>
        <view class="brief-item" bindtap="goMember">
          <text class="brief-num">{{memberInfo.cards}}</text>
          <text class="brief-label">次卡</text>
        </view>
      </view>
    </view>

    <!-- 功能菜单 -->
    <view class="glass-card">
      <view class="menu-item" bindtap="goMember">
        <text class="menu-icon">💳</text>
        <text class="menu-label">会员中心</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goOrders">
        <text class="menu-icon">📋</text>
        <text class="menu-label">消费记录</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goCards">
        <text class="menu-icon">🎫</text>
        <text class="menu-label">次卡管理</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goCoupons">
        <text class="menu-icon">🧧</text>
        <text class="menu-label">优惠券</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <!-- 更多设置 -->
    <view class="glass-card">
      <view class="menu-item" bindtap="onFeedback">
        <text class="menu-icon">💬</text>
        <text class="menu-label">意见反馈</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onSettings">
        <text class="menu-icon">⚙️</text>
        <text class="menu-label">设置</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" wx:if="{{isLoggedIn}}" bindtap="onLogout">
        <text class="menu-icon">🚪</text>
        <text class="menu-label" style="color:#e85c5c;">退出登录</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view style="height:40rpx;"></view>
  </view>
</view>
