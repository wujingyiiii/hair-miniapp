<!-- 登录/注册页 -->
<view class="login-page">
  <!-- 全屏背景 -->
  <view class="page-bg">
    <image src="/images/background.jpg" mode="aspectFill"></image>
  </view>

  <!-- 蒙层内容 -->
  <view class="login-overlay">
    <!-- 品牌区域 -->
    <view class="brand-section">
      <text class="brand-name">金手指美发</text>
      <text class="brand-slogan">你的专属美发护理专家</text>
    </view>

    <!-- ===== 微信授权手机号（主登录方式）===== -->
    <button
      class="wechat-auth-btn"
      open-type="getPhoneNumber"
      bindgetphonenumber="onGetPhoneNumber"
      loading="{{wxLoading}}"
    >
      <text class="wechat-icon">💬</text>
      <view class="wechat-text-wrap">
        <text class="wechat-main">微信一键登录</text>
        <!-- <text class="wechat-sub">新用户自动注册 · 免费快捷</text> -->
      </view>
      <text class="wechat-arrow">›</text>
    </button>

    <view class="free-tag">
      <text class="free-icon">✓</text>
      <text class="free-text">老用户一键登录</text>
    </view>

    <!-- ===== 分割线 ===== -->
    <view class="divider-row" bindtap="toggleSmsForm">
      <view class="divider-line"></view>
      <text class="divider-text">{{showSmsForm ? '收起' : '短信验证码登录'}}</text>
      <view class="divider-line"></view>
    </view>

    <!-- ===== 短信验证码登录（备用方式）===== -->
    <view class="sms-section {{showSmsForm ? 'expanded' : ''}}">
      <view class="login-card">
        <!-- 手机号输入 -->
        <view class="input-group">
          <text class="input-label">手机号</text>
          <view class="input-row">
            <text class="phone-prefix">+86</text>
            <input
              class="phone-input"
              type="text"
              maxlength="11"
              placeholder="请输入手机号"
              placeholder-style="color:#ccc"
              value="{{phone}}"
              bindinput="onPhoneInput"
            />
          </view>
          <view class="input-tip" wx:if="{{!isValidPhone && phone.length > 0}}">
            <text class="tip-text">请输入正确的11位手机号</text>
          </view>
        </view>

        <!-- 验证码输入 -->
        <view class="input-group">
          <text class="input-label">验证码</text>
          <view class="input-row">
            <input
              class="code-input"
              type="text"
              maxlength="6"
              placeholder="输入6位验证码"
              placeholder-style="color:#ccc"
              value="{{smsCode}}"
              bindinput="onCodeInput"
              disabled="{{!codeSent}}"
            />
            <button
              class="send-code-btn {{codeSending || !isValidPhone ? 'disabled' : ''}}"
              disabled="{{codeSending || !isValidPhone}}"
              bindtap="onSendCode"
            >
              <text wx:if="{{codeSending}}">发送中...</text>
              <text wx:elif="{{countdown > 0}}">{{countdown}}s</text>
              <text wx:else>{{codeBtnText}}</text>
            </button>
          </view>
        </view>

        <!-- 短信登录按钮 -->
        <button
          class="btn-primary sms-login-btn"
          disabled="{{!canLogin || logining}}"
          bindtap="onSmsLogin"
        >
          <text wx:if="{{logining}}">处理中...</text>
          <text wx:else>登录 / 注册</text>
        </button>
      </view>
    </view>

    <!-- 协议 -->
    <view class="agreement">
      <text class="agree-text">登录即表示同意</text>
      <text class="agree-link">《用户服务协议》</text>
      <text class="agree-text">及</text>
      <text class="agree-link">《隐私政策》</text>
    </view>
  </view>
</view>
