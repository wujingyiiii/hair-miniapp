/* 登录页 */
.login-page {
  position: relative;
  width: 100%;
  min-height: 100vh;
}

.login-overlay {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  padding-top: 20vh;
  box-sizing: border-box;
}

/* ===== 品牌区域 ===== */
.brand-section {
  text-align: center;
  margin-bottom: 60rpx;
}

.brand-name {
  font-size: 56rpx;
  font-weight: 700;
  color: #D4AF37;
  text-shadow: -2rpx -2rpx 0 #000, 2rpx -2rpx 0 #000, -2rpx 2rpx 0 #000, 2rpx 2rpx 0 #000;
  letter-spacing: 8rpx;
}

.brand-slogan {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  text-shadow: 0 2rpx 10rpx rgba(0,0,0,0.2);
}

/* ===== 微信授权按钮（主入口）===== */
.wechat-auth-btn {
  display: flex;
  align-items: center;
  width: 580rpx;
  height: 100rpx;
  background: #07c160;
  border-radius: 50rpx;
  border: none;
  padding: 0 32rpx;
  box-shadow: 0 8rpx 30rpx rgba(7, 193, 96, 0.35);
}

.wechat-auth-btn:active {
  opacity: 0.9;
}

.wechat-auth-btn::after {
  border: none;
}

.wechat-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.wechat-text-wrap {
  flex: 1;
  display: flex;
}

.wechat-main {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  white-space: nowrap;
}

.wechat-sub {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 4rpx;
}

.wechat-arrow {
  font-size: 36rpx;
  color: rgba(255,255,255,0.6);
  flex-shrink: 0;
}

/* 免费提示 */
.free-tag {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  gap: 6rpx;
}

.free-icon {
  font-size: 20rpx;
  color: rgba(255,255,255,0.6);
  font-weight: 700;
}

.free-text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
}

/* ===== 分割线 ===== */
.divider-row {
  display: flex;
  align-items: center;
  width: 580rpx;
  margin-top: 48rpx;
  padding: 10rpx 0;
}

.divider-line {
  flex: 1;
  height: 2rpx;
  background: rgba(255,255,255,0.2);
}

.divider-text {
  margin: 0 24rpx;
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
  flex-shrink: 0;
}

/* ===== 短信验证码区域（折叠）===== */
.sms-section {
  width: 100%;
  display: flex;
  justify-content: center;
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease;
}

.sms-section.expanded {
  max-height: 700rpx;
}

/* ===== 登录卡片 ===== */
.login-card {
  width: 580rpx;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 24rpx;
  padding: 40rpx 36rpx;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.1);
}

/* 输入组 */
.input-group {
  margin-bottom: 32rpx;
}

.input-label {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: #555;
  margin-bottom: 12rpx;
}

.input-row {
  display: flex;
  align-items: center;
  height: 88rpx;
  border-bottom: 2rpx solid #e8e8e8;
}

.phone-prefix {
  font-size: 28rpx;
  color: #333;
  margin-right: 16rpx;
  padding-right: 16rpx;
  border-right: 2rpx solid #e8e8e8;
  font-weight: 500;
  flex-shrink: 0;
}

.phone-input {
  flex: 1;
  height: 88rpx;
  font-size: 32rpx;
  color: #333;
}

.code-input {
  flex: 1;
  height: 88rpx;
  font-size: 32rpx;
  color: #333;
  letter-spacing: 8rpx;
}

.code-input[disabled] {
  color: #bbb;
}

/* 发送验证码按钮 */
.send-code-btn {
  flex-shrink: 0;
  width: 180rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  font-size: 24rpx;
  color: #333;
  background: #f5f5f5;
  border-radius: 30rpx;
  border: none;
  padding: 0;
}

.send-code-btn:not(.disabled):active {
  background: #e8e8e8;
}

.send-code-btn.disabled {
  color: #bbb;
  background: #f0f0f0;
}

/* 输入提示 */
.input-tip {
  margin-top: 8rpx;
}

.tip-text {
  font-size: 22rpx;
  color: #e85c5c;
}

/* 短信登录按钮 */
.sms-login-btn {
  margin-top: 10rpx;
  margin-bottom: 0;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
}

.sms-login-btn[disabled] {
  opacity: 0.5;
}

/* ===== 协议 ===== */
.agreement {
  text-align: center;
  margin-top: 40rpx;
  padding-bottom: 60rpx;
  font-size: 22rpx;
}

.agree-text {
  color: rgba(255,255,255,0.5);
}

.agree-link {
  color: rgba(255,255,255,0.7);
  text-decoration: underline;
}
