/* 会员中心 */
.page {
  position: relative;
  min-height: 100vh;
}

.content-area {
  position: relative;
  z-index: 1;
  padding-top: 16rpx;
}

/* VIP 金卡 */
.vip-card {
  background: linear-gradient(135deg, #2c2c2c, #1a1a1a, #3a3a3a) !important;
  text-align: center;
  padding: 40rpx 24rpx;
}

.vip-level {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #c4a265;
  margin-bottom: 12rpx;
}

.vip-no {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.4);
  margin-bottom: 24rpx;
}

.vip-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.vip-since {
  display: block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
}

/* 资产 */
.assets {
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.asset-item {
  text-align: center;
  flex: 1;
}

.asset-num {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.asset-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.asset-action {
  display: block;
  font-size: 20rpx;
  color: #c4a265;
  margin-top: 6rpx;
}

.asset-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(0,0,0,0.06);
}

/* 累计消费 */
.total-spent {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.spent-label {
  font-size: 28rpx;
  color: #666;
}

.spent-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #c4a265;
}

/* 菜单 */
.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid rgba(0,0,0,0.04);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-label {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.menu-arrow {
  font-size: 32rpx;
  color: #ccc;
}

/* 登录提示 */
.login-prompt {
  text-align: center;
  padding: 80rpx 40rpx;
  margin-top: 30vh;
}

.prompt-icon {
  font-size: 72rpx;
  display: block;
  margin-bottom: 20rpx;
}

.prompt-text {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}
