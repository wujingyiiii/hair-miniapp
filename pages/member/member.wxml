<!-- 会员中心 -->
<view class="page">
  <view class="page-bg">
  </view>

  <view class="content-area" wx:if="{{isLoggedIn && memberInfo}}">
    <!-- 会员金卡 -->
    <view class="glass-card vip-card">
      <text class="vip-level">{{memberInfo.level}}</text>
      <text class="vip-no">NO.{{memberInfo.memberNo}}</text>
      <text class="vip-name">{{userInfo.nickName || '会员'}}</text>
      <text class="vip-since">入会 {{memberInfo.joinDate}}</text>
    </view>

    <!-- 资产 -->
    <view class="glass-card assets">
      <view class="asset-item" bindtap="recharge">
        <text class="asset-num">¥{{memberInfo.balance}}</text>
        <text class="asset-label">余额</text>
        <text class="asset-action">充值 ›</text>
      </view>
      <view class="asset-divider"></view>
      <view class="asset-item">
        <text class="asset-num">{{memberInfo.points}}</text>
        <text class="asset-label">积分</text>
        <text class="asset-action">兑换 ›</text>
      </view>
      <view class="asset-divider"></view>
      <view class="asset-item" bindtap="goCards">
        <text class="asset-num">{{memberInfo.cards}}</text>
        <text class="asset-label">次卡</text>
        <text class="asset-action">查看 ›</text>
      </view>
    </view>

    <!-- 累计消费 -->
    <view class="glass-card">
      <view class="total-spent">
        <text class="spent-label">累计消费</text>
        <text class="spent-num">¥{{memberInfo.totalSpent || '0.00'}}</text>
      </view>
    </view>

    <!-- 功能列表 -->
    <view class="glass-card">
      <view class="menu-item" bindtap="goOrders">
        <text class="menu-icon">📋</text>
        <text class="menu-label">消费记录</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goCards">
        <text class="menu-icon">🎫</text>
        <text class="menu-label">次卡管理</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="recharge">
        <text class="menu-icon">💰</text>
        <text class="menu-label">余额充值</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goCoupons">
        <text class="menu-icon">🧧</text>
        <text class="menu-label">优惠券</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 未登录状态 -->
  <view class="content-area" wx:if="{{!isLoggedIn}}">
    <view class="glass-card login-prompt">
      <text class="prompt-icon">👤</text>
      <text class="prompt-text">登录后查看会员信息</text>
      <button class="btn-primary" bindtap="goLogin">去登录</button>
    </view>
  </view>

  <view style="height:40rpx;"></view>
</view>
