/* 首页 */
.page {
  position: relative;
  min-height: 100vh;
}

.content {
  position: relative;
  z-index: 1;
  height: 100vh;
  padding-top: 8rpx;
  box-sizing: border-box;
}

/* ===== 用户卡片 ===== */
.user-card {
  /* inherits .glass-card */
}

.user-row {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #333;
  color: #fff;
  text-align: center;
  line-height: 72rpx;
  font-size: 28rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.user-info {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.user-subtitle {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.member-tag {
  background: linear-gradient(135deg, #c4a265, #e8d5a3);
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

/* 资产行 */
.asset-row {
  display: flex;
  justify-content: space-around;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid rgba(0,0,0,0.05);
}

.asset-item {
  text-align: center;
}

.asset-num {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.asset-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

/* ===== 快捷入口 ===== */
.quick-grid {
  display: flex;
  flex-wrap: wrap;
}

.quick-item {
  width: 25%;
  text-align: center;
  padding: 12rpx 0;
}

.quick-icon {
  display: block;
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.quick-label {
  font-size: 24rpx;
  color: #555;
}

/* ===== 产品网格 ===== */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.section-more {
  font-size: 26rpx;
  color: #999;
}

.product-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.product-item {
  width: calc(50% - 8rpx);
  background: rgba(245,245,245,0.6);
  border-radius: 12rpx;
  padding: 16rpx;
  box-sizing: border-box;
}

.product-placeholder {
  width: 100%;
  height: 160rpx;
  background: rgba(200,200,200,0.3);
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.product-emoji {
  font-size: 48rpx;
}

.product-name {
  display: block;
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-price {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #c4a265;
  margin-top: 6rpx;
}

.product-sales {
  display: block;
  font-size: 20rpx;
  color: #bbb;
  margin-top: 4rpx;
}

/* ===== 服务列表 ===== */
.service-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 2rpx solid rgba(0,0,0,0.04);
}

.service-row:last-child {
  border-bottom: none;
}

.service-left {
  display: flex;
  align-items: center;
}

.service-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.service-name {
  font-size: 28rpx;
  color: #333;
}

.service-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.service-duration {
  font-size: 22rpx;
  color: #bbb;
}

.service-price {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}
